{
  "name": "@maille/api",
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "build": "SKIP_ENV_VALIDATION=1 bun build index.ts --compile --target=bun --outfile=dist/server",
    "dev": "bun run --watch index.ts | pino-pretty",
    "db:generate": "bunx drizzle-kit generate --dialect postgresql --schema ./src/tables.ts",
    "typecheck": "tsc",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@graphql-yoga/plugin-graphql-sse": "^3.21.0",
    "@maille/core": "*",
    "@pothos/core": "^4.12.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.13.2",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^5.21.0",
    "jose": "^5.10.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
